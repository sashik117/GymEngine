PORT=3000
AUTH_TOKEN_SECRET=change-this-long-random-secret
AUTH_CODE_TTL_MS=600000
AUTH_CODE_MAX_ATTEMPTS=5

# Real email delivery. If SMTP_HOST is empty, GymEngine writes messages to
# .data/mail/outbox.jsonl so local development can still test codes.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=GymEngine <your-email@gmail.com>
